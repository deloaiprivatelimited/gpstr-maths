  ],
  "theory": {
    "concept_summary": "ಛೇದಿಸುವ ರೇಖೆಗಳು ಸಾಮಾನ್ಯ ಬಿಂದುವನ್ನು ಹೊಂದಿದ್ದರೆ, ಸಮಾಂತರ ರೇಖೆಗಳು ಎಂದಿಗೂ ಛೇದಿಸುವುದಿಲ್ಲ. ಎರಡು ಅಥವಾ ಹೆಚ್ಚು ರೇಖೆಗಳನ್ನು ವಿಭಿನ್ನ ಬಿಂದುಗಳಲ್ಲಿ ಛೇದಿಸುವ ರೇಖೆಯನ್ನು ಛೇದಕ ಎನ್ನುತ್ತಾರೆ. ಛೇದಕವು ಅನುರೂಪ, ಪರ್ಯಾಯ ಅಂತರ್, ಪರ್ಯಾಯ ಬಾಹ್ಯ ಮತ್ತು ಛೇದಕದ ಒಂದೇ ಪಾರ್ಶ್ವದಲ್ಲಿರುವ ಅಂತರ್ ಕೋನಗಳಂತಹ ವಿವಿಧ ಕೋನ ಜೋಡಿಗಳನ್ನು ಸೃಷ್ಟಿಸುತ್ತದೆ. ಈ ಕೋನಗಳ ಸ್ಥಾನಗಳನ್ನು ಅರ್ಥಮಾಡಿಕೊಳ್ಳುವುದು ಸಮಾಂತರ ರೇಖೆಗಳ ಗುಣಲಕ್ಷಣಗಳನ್ನು ಅನ್ವಯಿಸಲು ನಿರ್ಣಾಯಕವಾಗಿದೆ.",
    "definitions": [
      {
        "term": "ಛೇದಿಸುವ ರೇಖೆಗಳು (Intersecting Lines)",
        "definition": "ಎರಡು ರೇಖೆಗಳು ಒಂದು ಸಾಮಾನ್ಯ ಬಿಂದುವನ್ನು ಹೊಂದಿದ್ದರೆ, ಅವುಗಳನ್ನು ಛೇದಿಸುವ ರೇಖೆಗಳು ಎನ್ನುತ್ತಾರೆ."
      },
      {
        "term": "ಸಮಾಂತರ ರೇಖೆಗಳು (Parallel Lines)",
        "definition": "ಒಂದೇ ಸಮತಲದಲ್ಲಿರುವ ಮತ್ತು ಪರಸ್ಪರ ಎಂದಿಗೂ ಛೇದಿಸದ ರೇಖೆಗಳನ್ನು ಸಮಾಂತರ ರೇಖೆಗಳು ಎನ್ನುತ್ತಾರೆ. ಅವುಗಳ ನಡುವಿನ ಲಂಬ ದೂರವು ಯಾವಾಗಲೂ ಸ್ಥಿರವಾಗಿರುತ್ತದೆ."
      },
      {
        "term": "ಛೇದಕ (Transversal)",
        "definition": "ಎರಡು ಅಥವಾ ಹೆಚ್ಚು ರೇಖೆಗಳನ್ನು ವಿಭಿನ್ನ ಬಿಂದುಗಳಲ್ಲಿ ಛೇದಿಸುವ ರೇಖೆಯನ್ನು ಛೇದಕ ಎನ್ನುತ್ತಾರೆ."
      },
      {
        "term": "ಅನುರೂಪ ಕೋನಗಳು (Corresponding Angles)",
        "definition": "ಛೇದಕದ ಒಂದೇ ಬದಿಯಲ್ಲಿ, ಮತ್ತು ಛೇದಿಸಲ್ಪಡುವ ರೇಖೆಗಳಿಗೆ ಸಂಬಂಧಿಸಿದಂತೆ ಒಂದೇ ರೀತಿಯ ಸ್ಥಾನದಲ್ಲಿರುವ (ಉದಾ: ಎರಡೂ ಮೇಲಿನ-ಬಲ) ಕೋನಗಳ ಜೋಡಿ."
      },
      {
        "term": "ಪರ್ಯಾಯ ಅಂತರ್ ಕೋನಗಳು (Alternate Interior Angles)",
        "definition": "ಛೇದಿಸಲ್ಪಡುವ ರೇಖೆಗಳ ನಡುವೆ (ಅಂತರ್) ಮತ್ತು ಛೇದಕದ ವಿರುದ್ಧ ಬದಿಗಳಲ್ಲಿರುವ ಕೋನಗಳ ಜೋಡಿ."
      },
      {
        "term": "ಪರ್ಯಾಯ ಬಾಹ್ಯ ಕೋನಗಳು (Alternate Exterior Angles)",
        "definition": "ಛೇದಿಸಲ್ಪಡುವ ರೇಖೆಗಳ ಹೊರಗೆ (ಬಾಹ್ಯ) ಮತ್ತು ಛೇದಕದ ವಿರುದ್ಧ ಬದಿಗಳಲ್ಲಿರುವ ಕೋನಗಳ ಜೋಡಿ."
      },
      {
        "term": "ಛೇದಕದ ಒಂದೇ ಪಾರ್ಶ್ವದಲ್ಲಿರುವ ಅಂತರ್ ಕೋನಗಳು (Consecutive Interior Angles)",
        "definition": "ಛೇದಿಸಲ್ಪಡುವ ರೇಖೆಗಳ ನಡುವೆ ಮತ್ತು ಛೇದಕದ ಒಂದೇ ಬದಿಯಲ್ಲಿರುವ ಕೋನಗಳ ಜೋಡಿ. ಇವುಗಳನ್ನು 'ಅನುಕ್ರಮ ಅಂತರ್ ಕೋನಗಳು' ಅಥವಾ 'ಪೂರಕ ಅಂತರ್ ಕೋನಗಳು' ಎಂದೂ ಕರೆಯುತ್ತಾರೆ."
      }
    ],
